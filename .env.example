# Required environment variables for the TonBrain bot
# Copy this file to .env and fill in your keys

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Google Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# TON Network (testnet or mainnet)
TON_NETWORK=testnet

# Optional: Toncenter API Key for higher rate limits
TONCENTER_API_KEY=

# Optional: TONAPI Key for NFT/jetton data  
TONAPI_KEY=
